Debug_Mode=False
# DASHSCOPE_API_KEY=sk-xxx   # 可选，也可在设置页输入

# 控制台主窗口：启动时的宽高（若在设置页保存过则优先用 config.json）
CONSOLE_WIDTH=1104
CONSOLE_HEIGHT=682
# 控制台主窗口：最小宽高（不可拖得更小；启动时若上面宽高小于此处则以此处为准）
CONSOLE_MIN_WIDTH=920
CONSOLE_MIN_HEIGHT=682

# 可选：CustomTkinter 圆角与 DPI（一般不填）
# CTK_DRAW_METHOD=font_shapes   # 圆角绘制方式：font_shapes | circle_shapes | polygon_shapes，默认 font_shapes；遇显示异常可改为 circle_shapes
# CTK_DEACTIVATE_DPI=1          # 仅当多屏拖拽导致报错或透明度异常时设为 1，会牺牲高 DPI 下清晰度
